# LateOS — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Messaging tool ───────────────────────────────────────────────────────────
# Adapt variable names to match your platform (Slack, Discord, Telegram, etc.)
# The simplest setup: a webhook URL. No bot setup required.

MESSAGING_WEBHOOK_URL=your_webhook_url_here

# Optional: secondary webhook for a separate channel
MESSAGING_SECONDARY_WEBHOOK_URL=your_secondary_webhook_url_here

# Optional: bot token for interactive features (buttons, modals)
# Without this, notifications work but without interactive elements.
MESSAGING_BOT_TOKEN=your_bot_token_here

# Optional: app-level token for real-time bot features (platform-specific)
MESSAGING_APP_TOKEN=your_app_token_here

# Channel or destination ID where the bot posts
MESSAGING_CHANNEL_ID=your_channel_id_here

# ─── LLM ─────────────────────────────────────────────────────────────────────
# Any OpenAI-compatible API works. Update the client in llm_scorer.py to switch.
# Examples: Groq (free tier), OpenAI, Anthropic, local Ollama

LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# ─── Search ──────────────────────────────────────────────────────────────────
# Used for source_search.py — finds results on specific sites via Google.
# Compatible with Serper, SerpAPI, Tavily, or any search API.

SEARCH_API_KEY=your_search_api_key_here

# ─── Transcription ───────────────────────────────────────────────────────────
# Used by transcribe_call.py. Compatible with AssemblyAI, Deepgram, Whisper API.

TRANSCRIPTION_API_KEY=your_transcription_api_key_here

# ─── Optional: external content source ───────────────────────────────────────
# If you pull content from a messaging platform (e.g. Discord, Slack channel)
# as a digest source, add its credentials here.

CONTENT_SOURCE_BOT_TOKEN=your_content_source_bot_token_here
CONTENT_SOURCE_CHANNEL_ID=your_content_source_channel_id_here
