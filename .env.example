# LateOS — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Slack ───────────────────────────────────────────────────────────────────

# Webhook URL for Slack notifications (required for basic alerts)
# Create at: api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Secondary webhook for a separate Slack channel (optional)
SLACK_DAILY_WEBHOOK_URL=your_secondary_webhook_url_here

# Bot token for interactive message buttons (optional)
# Without this, notifications work but without interactive elements.
# Requires: api.slack.com/apps → OAuth & Permissions → chat:write, channels:read
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level token for Socket Mode (optional, required only for real-time bot features)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Channel ID where the bot posts (required if using bot token)
# Find it: right-click channel in Slack → Copy Link → last segment is the ID
SLACK_CHANNEL_ID=C0000000000

# ─── LLM ─────────────────────────────────────────────────────────────────────

# Groq API key for LLM analysis (free tier is sufficient for daily use)
# LateOS uses Groq for its generous free tier. Any OpenAI-compatible API works —
# update the client in llm_scorer.py to switch providers.
# Get key at: console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Model to use — free tier options:
# llama-3.3-70b-versatile — best quality, recommended
# mixtral-8x7b-32768 — faster, slightly lower quality
# gemma2-9b-it — lightest, good for high volume
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Search ──────────────────────────────────────────────────────────────────

# Serper API key for Google search queries
# Used to find results from specific sites via Google.
# Get key at: serper.dev (free tier: 2500 queries/month)
SERPER_API_KEY=your_serper_api_key_here

# ─── Optional integrations ───────────────────────────────────────────────────

# Tavily API key for web search and content extraction (optional)
# Get key at: tavily.com
TAVILY_API_KEY=tvly-your-tavily-key-here

# AssemblyAI API key for audio transcription (optional)
# Get key at: assemblyai.com
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# Discord bot token for reading messages from a channel (optional)
# Requires: Message Content Intent enabled in discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=000000000000000000
